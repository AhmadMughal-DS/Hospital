# ─────────────────────────────────────────────────────────────────
# MediCore HMS — Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit the actual .env file to git
# ─────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────
DEBUG=0
SECRET_KEY=your-production-secret-key-min-50-chars-random-string

# ── Database ──────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=hms_db
DB_USER=hms_user
DB_PASSWORD=your-strong-db-password

# ── CORS & Hosts ──────────────────────────────────────────────────
ALLOWED_HOSTS=hospital.ahmaddataops.com
CORS_ALLOWED_ORIGINS=https://hospital.ahmaddataops.com

# ── Email (Gmail SMTP) ────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# ── Stripe Payments ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Docker / CI ───────────────────────────────────────────────────
DOCKER_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# ── Frontend (Vite build args) ────────────────────────────────────
VITE_DJANGO_API_BASE=https://hospital.ahmaddataops.com
VITE_QUEUE_API_BASE=https://hospital.ahmaddataops.com
